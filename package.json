{
  "name": "new_bot",
  "version": "1.0.0",
  "description": "WhatsApp Bot with multi-language support",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:web": "cross-env NODE_ENV=production node dist/index.js",
    "start:worker": "cross-env NODE_ENV=production node dist/worker.js",
    "dev:web": "nodemon --watch 'src/**/*.ts' --exec 'node --loader ts-node/esm' src/index.ts",
    "dev:worker": "nodemon --watch 'src/**/*.ts' --exec 'node --loader ts-node/esm' src/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "bugs": {
    "url": "https://github.com/soumyachk101/New-Bot/issues"
  },
  "homepage": "https://github.com/soumyachk101/New-Bot#readme",
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.0.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
